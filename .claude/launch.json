{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Dev Server (Svelte)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "client"
    },
    {
      "name": "Express + Socket.io Backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "index.js"],
      "port": 3000,
      "cwd": "server"
    },
    {
      "name": "Railway (Production)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/index.js"],
      "port": 8080,
      "env": {
        "PORT": "8080",
        "NODE_ENV": "production"
      }
    }
  ]
}
